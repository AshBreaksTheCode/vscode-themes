  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#3b4a6b",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "comment.line.double-slash",
      "settings": {
        "foreground": "#3b4a6b",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "comment.block.documentation",
      "settings": {
        "foreground": "#4a5a80",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#f472b6"
      }
    },
    {
      "scope": "string.quoted.docstring",
      "settings": {
        "foreground": "#4a5a80",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "constant.character.escape",
      "settings": {
        "foreground": "#fb923c"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.other"
      ],
      "settings": {
        "foreground": "#fb923c"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.definition.keyword"
      ],
      "settings": {
        "foreground": "#a78bfa"
      }
    },
    {
      "scope": "keyword.operator.logical",
      "settings": {
        "foreground": "#a78bfa"
      }
    },
    {
      "scope": "keyword.control.import",
      "settings": {
        "foreground": "#a78bfa"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "support.macro"
      ],
      "settings": {
        "foreground": "#60a5fa"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#c084fc"
      }
    },
    {
      "scope": "entity.other.attribute-name",
      "settings": {
        "foreground": "#22d3ee"
      }
    },
    {
      "scope": "entity.name.tag",
      "settings": {
        "foreground": "#22d3ee"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other"
      ],
      "settings": {
        "foreground": "#e8e0f0"
      }
    },
    {
      "scope": [
        "variable.language",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#d0c8e0"
      }
    },
    {
      "scope": "variable.other.constant",
      "settings": {
        "foreground": "#fb923c"
      }
    },
    {
      "scope": "variable.other.property",
      "settings": {
        "foreground": "#e8e0f0"
      }
    },
    {
      "scope": [
        "support.variable",
        "support.constant"
      ],
      "settings": {
        "foreground": "#fb923c"
      }
    },
    {
      "scope": "punctuation",
      "settings": {
        "foreground": "#6a5a8a"
      }
    },
    {
      "scope": "punctuation.definition.parameters",
      "settings": {
        "foreground": "#6a5a8a"
      }
    },
    {
      "scope": "punctuation.definition.bracket",
      "settings": {
        "foreground": "#c084fc"
      }
    },
    {
      "scope": [
        "meta.brace",
        "punctuation.section"
      ],
      "settings": {
        "foreground": "#6a5a8a"
      }
    },
    {
      "scope": "meta.tag",
      "settings": {
        "foreground": "#22d3ee"
      }
    },
    {
      "scope": "meta.tag.value",
      "settings": {
        "foreground": "#f472b6"
      }
    },
    {
      "scope": "meta.selector",
      "settings": {
        "foreground": "#c084fc"
      }
    },
    {
      "scope": "meta.preprocessor",
      "settings": {
        "foreground": "#a78bfa"
      }
    },
    {
      "scope": "meta.diff",
      "settings": {
        "foreground": "#d0c8e0"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#34d399"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#e04080"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#fbbf24"
      }
    },
    {
      "scope": "markup.heading",
      "settings": {
        "foreground": "#f472b6",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#60a5fa",
        "fontStyle": "underline"
      }
    },
    {
      "scope": "markup.list",
      "settings": {
        "foreground": "#22d3ee"
      }
    },
    {
      "scope": "markup.quote",
      "settings": {
        "foreground": "#4a5a80",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "markup.inline.raw",
      "settings": {
        "foreground": "#f472b6"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.id",
        "entity.other.attribute-name.class"
      ],
      "settings": {
        "foreground": "#d0c8e0"
      }
    },
    {
      "scope": "source.css entity.name.tag",
      "settings": {
        "foreground": "#c084fc"
      }
    },
    {
      "scope": "support.type.property-name",
      "settings": {
        "foreground": "#d0c8e0"
      }
    },
    {
      "scope": "meta.property-name",
      "settings": {
        "foreground": "#d0c8e0"
      }
    },
    {
      "scope": "source.css meta.property-value variable",
      "settings": {
        "foreground": "#f472b6"
      }
    },
    {
      "scope": "keyword.unit",
      "settings": {
        "foreground": "#fb923c"
      }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#e04080",
        "background": "#1a0a20"
      }
    },
    {
      "scope": "invalid.deprecated",
      "settings": {
        "foreground": "#fbbf24",
        "background": "#1a1a0a"
      }
    },
    {
      "scope": "debug",
      "settings": {
        "foreground": "#d0c8e0"
      }
    },
    {
      "scope": "string.regexp",
      "settings": {
        "foreground": "#22d3ee"
      }
    },
    {
      "scope": "string.regexp keyword.operator",
      "settings": {
        "foreground": "#22d3ee"
      }
    }
  ],
  "semanticTokenColors": {
    "newOperator": "#a78bfa",
    "stringLiteral": "#f472b6",
    "numberLiteral": "#fb923c",
    "typeAlias": "#c084fc",
    "enumMember": "#c084fc",
    "class": "#c084fc",
    "interface": "#c084fc",
    "method": "#60a5fa",
    "property": "#e8e0f0",
    "variable.readonly": "#fb923c",
    "variable.defaultLibrary": "#fb923c"
  }
}
