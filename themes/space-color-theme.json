    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#d06090",
        "background": "#2a1030"
      }
    },
    {
      "scope": "invalid.deprecated",
      "settings": {
        "foreground": "#d0d060",
        "background": "#2a2a10"
      }
    },
    {
      "scope": "debug",
      "settings": {
        "foreground": "#c0c0d8"
      }
    },
    {
      "scope": "string.regexp",
      "settings": {
        "foreground": "#60d0d0"
      }
    },
    {
      "scope": "string.regexp keyword.operator",
      "settings": {
        "foreground": "#60d0d0"
      }
    }
