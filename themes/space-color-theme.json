      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#d0d060"
      }
    },
    {
      "scope": "markup.heading",
      "settings": {
        "foreground": "#f0a0d0",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#6090f0",
        "fontStyle": "underline"
      }
    },
    {
      "scope": "markup.list",
      "settings": {
        "foreground": "#e8a0bf"
      }
    },
    {
      "scope": "markup.quote",
      "settings": {
        "foreground": "#5a6590",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "markup.inline.raw",
      "settings": {
        "foreground": "#f0a0d0"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.id",
        "entity.other.attribute-name.class"
      ],
      "settings": {
        "foreground": "#d0c0e8"
      }
    },
    {
      "scope": "source.css entity.name.tag",
      "settings": {
        "foreground": "#a07ae0"
      }
    },
    {
      "scope": "support.type.property-name",
      "settings": {
        "foreground": "#d0c0e8"
      }
    },
    {
      "scope": "meta.property-name",
      "settings": {
        "foreground": "#d0c0e8"
      }
    },
    {
      "scope": "source.css meta.property-value variable",
      "settings": {
        "foreground": "#f0a0d0"
      }
    },
    {
      "scope": "keyword.unit",
      "settings": {
        "foreground": "#ff80b0"
      }
