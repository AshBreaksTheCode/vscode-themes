  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#4a5580",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "comment.line.double-slash",
      "settings": {
        "foreground": "#4a5580",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "comment.block.documentation",
      "settings": {
        "foreground": "#5a6590",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#f0a0d0"
      }
    },
    {
      "scope": "string.quoted.docstring",
      "settings": {
        "foreground": "#5a6590",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "constant.character.escape",
      "settings": {
        "foreground": "#ff80b0"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.other"
      ],
      "settings": {
        "foreground": "#ff80b0"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator",
        "punctuation.definition.keyword"
      ],
      "settings": {
        "foreground": "#8b7cf0"
      }
    },
    {
      "scope": "keyword.operator.logical",
      "settings": {
        "foreground": "#8b7cf0"
      }
    },
    {
      "scope": "keyword.control.import",
      "settings": {
        "foreground": "#8b7cf0"
      }
    },
    {
      "scope": "storage",
      "settings": {
        "foreground": "#8b7cf0"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#8b7cf0"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "support.macro"
      ],
      "settings": {
        "foreground": "#60a5fa"
