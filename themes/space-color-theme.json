      }
    },
    {
      "scope": [
        "variable.language",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#d0c0e8"
      }
    },
    {
      "scope": "variable.other.constant",
      "settings": {
        "foreground": "#ff80b0"
      }
    },
    {
      "scope": "variable.other.property",
      "settings": {
