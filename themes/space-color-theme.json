  "semanticTokenColors": {
    "newOperator": "#8b7cf0",
    "stringLiteral": "#f0a0d0",
    "numberLiteral": "#ff80b0",
    "typeAlias": "#a07ae0",
    "enumMember": "#a07ae0",
    "class": "#a07ae0",
    "interface": "#a07ae0",
    "method": "#60a5fa",
    "property": "#e0e0f0",
    "variable.readonly": "#ff80b0",
    "variable.defaultLibrary": "#ff80b0"
  }
