  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#7d6a7e",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "comment.line.double-slash",
      "settings": {
        "foreground": "#7d6a7e",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "comment.block.documentation",
      "settings": {
        "foreground": "#8b7a8e",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#f4b8d0"
      }
    },
    {
      "scope": "string.quoted.docstring",
      "settings": {
        "foreground": "#8b7a8e",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "constant.character.escape",
