{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "forestBg":     "#1a2318",
    "darkerBg":     "#161e15",
    "lighterBg":    "#1e2a1c",
    "textLight":    "#d4d0c8",
    "textMuted":    "#4a5a4a",
    "leafGreen":    "#a8d5a2",
    "skyBlue":      "#8cb4d4",
    "fairyGold":    "#f0d58c",
    "magicPurple":  "#b8a9d4",
    "berryPink":    "#d4738a",
    "mossGreen":    "#4d7a48",
    "warmWhite":    "#d4d0c8"
  },
  "theme": {
    "primary":      "fairyGold",
    "secondary":    "leafGreen",
    "accent":       "skyBlue",
    "error":        "berryPink",
    "warning":      "fairyGold",
    "success":      "mossGreen",
    "info":         "skyBlue",

    "text":              "textLight",
    "textMuted":         "textMuted",
    "selectedListItemText": "textLight",

    "background":        "forestBg",
    "backgroundPanel":   "darkerBg",
    "backgroundElement": "lighterBg",
    "backgroundMenu":    "darkerBg",

    "border":       "#223021",
    "borderActive": "leafGreen",
    "borderSubtle": "#1a2a1a",

    "diffAdded":         "mossGreen",
    "diffRemoved":       "berryPink",
    "diffContext":       "#4a5a4a",
    "diffHunkHeader":    "leafGreen",
    "diffHighlightAdded":   "#6a9a60",
    "diffHighlightRemoved": "#e0807a",
    "diffAddedBg":          "#1a3a1a20",
    "diffRemovedBg":        "#3a1a2020",
    "diffContextBg":        "darkerBg",
    "diffLineNumber":       "#3a4a3a",
    "diffAddedLineNumberBg":   "#1a3a1a20",
    "diffRemovedLineNumberBg": "#3a1a2020",

    "markdownText":           "textLight",
    "markdownHeading":        "fairyGold",
    "markdownLink":           "skyBlue",
    "markdownLinkText":       "magicPurple",
    "markdownCode":           "fairyGold",
    "markdownBlockQuote":     "textMuted",
    "markdownEmph":           "leafGreen",
    "markdownStrong":         "fairyGold",
    "markdownHorizontalRule": "#2a3a28",
    "markdownListItem":       "berryPink",
    "markdownListEnumeration":"skyBlue",
    "markdownImage":          "skyBlue",
    "markdownImageText":      "magicPurple",
    "markdownCodeBlock":      "textLight",

    "syntaxComment":     "#4a5a4a",
    "syntaxKeyword":     "leafGreen",
    "syntaxFunction":    "skyBlue",
    "syntaxVariable":    "textLight",
    "syntaxString":      "fairyGold",
    "syntaxNumber":      "#e8a060",
    "syntaxType":        "leafGreen",
    "syntaxOperator":    "magicPurple",
    "syntaxPunctuation": "#5a6a5a",

    "thinkingOpacity": 0.4
  }
