{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "purpleBg":     "#1e1438",
    "darkerBg":     "#1a1130",
    "lighterBg":    "#241a40",
    "textLight":    "#22d3ee",
    "textMuted":    "#1a90a8",
    "nebulaPink":   "#f472b6",
    "starlightBlue":"#60a5fa",
    "cosmicPurple": "#a78bfa",
    "lightPurple":  "#c084fc",
    "cosmicOrange": "#fb923c",
    "nebulaCyan":   "#22d3ee",
    "starWhite":    "#e8e0f0",
    "starYellow":   "#facc15"
  },
  "theme": {
    "primary":      "nebulaPink",
    "secondary":    "starlightBlue",
    "accent":       "nebulaCyan",
    "error":        "#ef4444",
    "warning":      "#fbbf24",
    "success":      "#34d399",
    "info":         "starlightBlue",

    "text":              "textLight",
    "textMuted":         "textMuted",
    "selectedListItemText": "textLight",

    "background":        "purpleBg",
    "backgroundPanel":   "darkerBg",
    "backgroundElement": "lighterBg",
    "backgroundMenu":    "darkerBg",

    "border":       "#2a1d50",
    "borderActive": "cosmicPurple",
    "borderSubtle": "#221640",

    "diffAdded":         "#34d399",
    "diffRemoved":       "#ef4444",
    "diffContext":       "#5a4a7a",
    "diffHunkHeader":    "cosmicPurple",
    "diffHighlightAdded":   "#4ade80",
    "diffHighlightRemoved": "#f87171",
    "diffAddedBg":          "#1a3a2020",
    "diffRemovedBg":        "#3a1a2820",
    "diffContextBg":        "darkerBg",
    "diffLineNumber":       "#3a2a5a",
    "diffAddedLineNumberBg":   "#1a3a2020",
    "diffRemovedLineNumberBg": "#3a1a2820",

    "markdownText":           "textLight",
    "markdownHeading":        "nebulaPink",
    "markdownLink":           "starlightBlue",
    "markdownLinkText":       "nebulaCyan",
    "markdownCode":           "starYellow",
    "markdownBlockQuote":     "textMuted",
    "markdownEmph":           "cosmicPurple",
    "markdownStrong":         "nebulaPink",
    "markdownHorizontalRule": "#2a1d50",
    "markdownListItem":       "nebulaCyan",
    "markdownListEnumeration":"starlightBlue",
    "markdownImage":          "starlightBlue",
    "markdownImageText":      "nebulaCyan",
    "markdownCodeBlock":      "starYellow",

    "syntaxComment":     "#5a4a7a",
    "syntaxKeyword":     "cosmicPurple",
    "syntaxFunction":    "starlightBlue",
    "syntaxVariable":    "textLight",
    "syntaxString":      "starYellow",
    "syntaxNumber":      "cosmicOrange",
    "syntaxType":        "lightPurple",
    "syntaxOperator":    "cosmicPurple",
    "syntaxPunctuation": "#6a5a8a",

    "thinkingOpacity": 0.4
  }
}
