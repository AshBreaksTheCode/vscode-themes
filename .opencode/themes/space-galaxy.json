{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "purpleBg":     "#d9abff",
    "darkerBg":     "#c99af0",
    "lighterBg":    "#d0a0f5",
    "textLight":    "#1e1438",
    "textMuted":    "#4a2a6a",
    "nebulaPink":   "#f472b6",
    "starlightBlue":"#60a5fa",
    "cosmicPurple": "#a78bfa",
    "lightPurple":  "#c084fc",
    "cosmicOrange": "#fb923c",
    "nebulaCyan":   "#22d3ee",
    "starWhite":    "#e8e0f0",
    "starYellow":   "#facc15",
    "babyBlue":     "#7dd3fc"
  },
  "theme": {
    "primary":      "nebulaPink",
    "secondary":    "starlightBlue",
    "accent":       "nebulaCyan",
    "error":        "#ef4444",
    "warning":      "#fbbf24",
    "success":      "#34d399",
    "info":         "starlightBlue",

    "text":              "textLight",
    "textMuted":         "textMuted",
    "selectedListItemText": "textLight",

    "background":        "purpleBg",
    "backgroundPanel":   "darkerBg",
    "backgroundElement": "lighterBg",
    "backgroundMenu":    "darkerBg",

    "border":       "#c08aeb",
    "borderActive": "cosmicPurple",
    "borderSubtle": "#c99af0",

    "diffAdded":         "#34d399",
    "diffRemoved":       "#ef4444",
    "diffContext":       "#8a6aaa",
    "diffHunkHeader":    "cosmicPurple",
    "diffHighlightAdded":   "#34d399",
    "diffHighlightRemoved": "#f87171",
    "diffAddedBg":          "#d4f4d420",
    "diffRemovedBg":        "#fce4ec20",
    "diffContextBg":        "#d0a0f5",
    "diffLineNumber":       "#8a6aaa",
    "diffAddedLineNumberBg":   "#d4f4d420",
    "diffRemovedLineNumberBg": "#fce4ec20",

    "markdownText":           "textLight",
    "markdownHeading":        "nebulaPink",
    "markdownLink":           "starlightBlue",
    "markdownCode":           "babyBlue",
    "markdownLinkText":       "babyBlue",
    "markdownEmph":           "cosmicPurple",
    "markdownStrong":         "nebulaPink",
    "markdownHorizontalRule": "#2a1d50",
    "markdownListItem":       "babyBlue",
    "markdownListEnumeration":"starlightBlue",
    "markdownImage":          "starlightBlue",
    "markdownImageText":      "babyBlue",
    "markdownCodeBlock":      "babyBlue",

    "syntaxComment":     "#8a6aaa",
    "syntaxKeyword":     "starYellow",
    "syntaxFunction":    "starlightBlue",
    "syntaxVariable":    "textLight",
    "syntaxString":      "nebulaCyan",
    "syntaxNumber":      "cosmicOrange",
    "syntaxType":        "lightPurple",
    "syntaxOperator":    "starYellow",
    "syntaxPunctuation": "#7a5a9a",

    "thinkingOpacity": 0.4
  }
}
